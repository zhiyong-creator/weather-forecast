page {
  -webkit-font-smoothing: antialiased;
  font-family: "PingHei","Helvetica Neue","Helvetica","Arial","Verdana","sans-serif";
}
.num {
  font-weight: 300;
}
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  color: #fff;
  font-size: 30rpx;
}
.bcg {
  position: fixed;
  z-index: 2;
  height: 100%;
  width: 100%;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}
.search {
  position: fixed;
  z-index: 4;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 90rpx;
}
.search .wrapper {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  font-size: 28rpx;
  height: 60rpx;
  margin: 15rpx 50rpx;
  padding: 0 15rpx;
  box-sizing: border-box;
  border: none;
  border-bottom: 1rpx solid rgba(255, 255, 255, .6);
  background: rgba(0, 0, 0, .15);
  border-radius: 12rpx;
}
.search image {
  width: 28rpx;
  height: 28rpx;
  margin-right: 16rpx;
}
.search input {
  flex: 1;
  color: #fff;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,.4);
}
.placeholderClass {
  color: rgba(255, 255, 255, .85);
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,.4);
}
.chooseBcg {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  position: fixed;
  z-index: 100;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  font-size: 24rpx;
  color: #333;
}
.chooseBcg .top {
  box-sizing: border-box;
  padding: 20rpx 20rpx 50rpx;
  background: rgba(255, 255, 255, 0);
  color: #fff;
}
.chooseBcg .bcgs {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  overflow: scroll;
}
.chooseBcg .border {
  padding: 6rpx;
  margin-right: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0);
  transition: .1s ease;
}
.chooseBcg .border:last-child {
  margin-right: 0;
}
.chooseBcg .border.active {
  border: 1rpx solid #40a7e7;
  transition: .1s ease;
}
.chooseBcg .bcgs image {
  width: 110rpx;
  height: 190rpx;
}
.chooseBcg .close {
  flex: 1;
  background: rgba(0, 0, 0, 0);
  padding: 20rpx 0;
  text-align: center;
}
.chooseBcg .close image {
  width: 64rpx;
  height: 64rpx;
}
.avatarInfo {
  display: flex;
  align-items: center;
  padding: 0 50rpx;
}
.avatarInfo .avatar {
  display: block;
  overflow: hidden;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}
.avatarInfo .name {
  padding: 0 20rpx;
  font-size: 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,.5);
}
.container .content {
  flex: 2;
  transition: .3s ease;
}
.content {
  position: relative;
  z-index: 2;
}
.info {
  padding: 10rpx 0 50rpx;
}
.info .temp,
.info .pm,
.info .pm view,
.info .weather {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}
.info .weather {
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,.35);
}
.info .pm text {
  font-size: 24rpx;
  height: 1em;
  line-height: 1em;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(240, 240, 240, .2);
}
.city {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  padding: 0 50rpx;
  font-size: 66rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,.4);
}
.city .name {
  display: flex;
  justify-content: center;
  align-items: center;
}
.city .name .val {
  max-width: 5em;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
.city .name .icon,
.city .name .down {
  width: 30rpx;
  height: 30rpx;
}
.city .name .icon {
  margin-right: 20rpx;
}
.city .name .down {
  margin-left: 20rpx;
}
.city .time {
  display: block;
  text-align: right;
  font-size: 24rpx;
}
.message {
  font-size: 24rpx;
  color: #fff;
  padding: 20rpx 50rpx 0;
  box-sizing: border-box;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,.4);
}
.temp {
  height: 360rpx;
  font-size: 200rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,.3);
}
.dailyForecast .forecasts {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,.35), rgba(0,0,0,.55));
  margin-bottom: 20rpx;
  overflow-x: auto;
}
.dailyForecast .title,
.hourly .title,
.livingIndextitle,
.show-title {
  border-bottom: 1rpx solid rgba(250, 250, 250, .2);
  background: rgba(0, 0, 0, .6);
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
}
.dailyForecast .item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
  flex-shrink: 0;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, .08);
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, .12);
  backdrop-filter: blur(4rpx);
  transition: .2s ease;
}
.dailyForecast .item:active {
  background: rgba(255, 255, 255, .15);
}
.dailyForecast .day-label {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}
.dailyForecast .date-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, .8);
  margin-bottom: 20rpx;
}
.dailyForecast .weather-icon {
  font-size: 26rpx;
  margin-bottom: 18rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, .08);
  border-radius: 20rpx;
}
.dailyForecast .temp-group {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 14rpx;
}
.dailyForecast .temp-max {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}
.dailyForecast .temp-min {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, .85);
}
.dailyForecast .temp-bar {
  flex: 1;
  height: 4rpx;
  margin: 0 10rpx;
  background: rgba(255, 255, 255, .15);
  border-radius: 2rpx;
  overflow: hidden;
}
.dailyForecast .temp-bar-fill {
  height: 100%;
  width: 60%;
  background: linear-gradient(90deg, #60a5fa, #f97373);
  border-radius: 2rpx;
}
.dailyForecast .wind-info {
  font-size: 24rpx;
  color: #fff;
  text-align: center;
}
.hourly {
  margin-bottom: 20rpx;
}
.hourly .hours {
  display: flex;
  flex-wrap: nowrap;
  background: rgba(0, 0, 0, .5);
  padding: 6rpx 12rpx;
  overflow-x: auto;
}
.hourly .hour {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 100rpx;
  position: relative;
}
.hourly .hour::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1rpx;
  background: rgba(255, 255, 255, .06);
}
.hourly .hour:last-child::after {
  display: none;
}
.hourly .hour .time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, .85);
  line-height: 1.6;
  margin-bottom: 4rpx;
}
.hourly .hour .temp {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.5;
  margin-bottom: 6rpx;
}
.hourly .hour .weather {
  font-size: 24rpx;
  color: #fff;
  line-height: 1.5;
  margin-bottom: 4rpx;
}
.hourly .hour .wind {
  font-size: 22rpx;
  color: rgba(255, 255, 255, .8);
  line-height: 1.4;
}
.livingIndex {
  margin-bottom: 20rpx;
}
.livingIndex .indexes {
  display: flex;
  flex-wrap: nowrap;
  background: rgba(0, 0, 0, .45);
  padding: 24rpx 20rpx;
  white-space: nowrap;
}
.livingIndex .item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  flex-shrink: 0;
  padding: 20rpx 16rpx 24rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, .06);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, .06);
  white-space: normal;
  word-break: break-all;
}
.livingIndex .item:last-child {
  margin-right: 0;
}
.livingIndex .item .icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}
.livingIndex .item .info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 10rpx;
}
.livingIndex .item .name {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 4rpx;
}
.livingIndex .item .category {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffd700;
}
.livingIndex .item .text {
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  color: #fff;
}
.details {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  background: rgba(0, 0, 0, .6);
  margin-bottom: 20rpx;
  font-size: 24rpx;
}
.details .detail {
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  padding: 14rpx 0;
  height: 110rpx;
  width: 25%;
  border-right: 1rpx solid rgba(250, 250, 250, 0.2);
  border-bottom: 1rpx solid rgba(250, 250, 250, 0.2);
  box-sizing: border-box;
}
.details .detail:nth-child(4n) {
  border-right: none;
}
.details .detail:nth-child(n+9) {
  border-bottom: none;
}
.details .detail .label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, .6);
}
.details .detail .value {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}
.openSettingButton {
  position: fixed;
  z-index: 102;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, .5);
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}
.openSettingButton image {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  z-index: 2;
}
.openSettingButton button {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  opacity: 0;
  z-index: 3;
}
.footer {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 60rpx;
  font-size: 22rpx;
  color: #fff;
}
